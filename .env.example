# 环境变量配置示例
# 复制此文件为 .env 并填入实际配置值

# ===========================================
# LLM配置 (支持配置多个LLM)
# ===========================================
# 注意: 序号可以不连续，系统会自动按从小到大排序
# 例如: LLM_1, LLM_3, LLM_5 会按顺序解析为第1、2、3个LLM

# 第一个 LLM 配置 - OpenAI 兼容 API (必填)
LLM_1_NAME=openai
LLM_1_API_KEY=your-api-key-here
LLM_1_API_URL=https://api.openai.com/v1
LLM_1_MODEL=gpt-4
LLM_1_TIMEOUT=120
LLM_1_API_TYPE=openai
# LLM_1_PROXY=http://127.0.0.1:7890
# LLM_1_EXTRA={"extra_body":{"enable_thinking":true}}

# 第二个 LLM 配置 - Anthropic API (可选)
# LLM_2_NAME=claude
# LLM_2_API_KEY=your-claude-api-key-here
# LLM_2_API_URL=https://api.anthropic.com
# LLM_2_MODEL=claude-3-5-sonnet-20241022
# LLM_2_TIMEOUT=120
# LLM_2_API_TYPE=anthropic
# LLM_2_PROXY=http://127.0.0.1:7890
# LLM_2_EXTRA={"default_headers":{"anthropic-beta":"prompt-caching-2024-07-31"}}

# 第三个 LLM 配置 - DeepSeek API (可选)
# DeepSeek 推理模型（如 deepseek-reasoner）需要使用 deepseek 类型
# 以正确处理 reasoning_content 字段
# LLM_3_NAME=deepseek
# LLM_3_API_KEY=your-deepseek-api-key-here
# LLM_3_API_URL=https://api.deepseek.com
# LLM_3_MODEL=deepseek-reasoner
# LLM_3_TIMEOUT=120
# LLM_3_API_TYPE=deepseek
# LLM_3_PROXY=http://127.0.0.1:7890
# LLM_3_EXTRA={"temperature":0}

# 第四个 LLM 配置 - OpenAI Responses API (可选)
# 某些 API 只支持 OpenAI Responses 格式接口（非 Chat Completions API）
# 使用 openai 类型，并在 EXTRA 中开启 use_responses_api
# LLM_4_NAME=openai-responses
# LLM_4_API_KEY=your-api-key-here
# LLM_4_API_URL=https://api.example.com/v1
# LLM_4_MODEL=gpt-4
# LLM_4_TIMEOUT=120
# LLM_4_API_TYPE=openai
# LLM_4_PROXY=http://127.0.0.1:7890
# LLM_4_EXTRA={"use_responses_api":true,"use_previous_response_id":false,"reasoning":{"effort":"low","summary":"auto"}}

# ===========================================
# MCP 配置
# ===========================================
# MCP_CONFIG_FILEPATH: MCP 配置文件路径
# 默认值: 当前工作目录下的 mcp.json
# 例如: MCP_CONFIG_FILEPATH=/path/to/mcp.json
# MCP_CONFIG_FILEPATH=mcp.json

# ===========================================
# 解题配置参数
# ===========================================
# MAX_ITERATIONS: LangGraph图执行步数上限，每次工具调用约消耗2步
# 默认值: 120 (约等于60次工具调用)
MAX_ITERATIONS=300

# MAX_ROUNDS: LLM切换轮数上限
# 默认值: 10
MAX_ROUNDS=10

# ===========================================
# RAG 配置参数
# ===========================================
# RAG_DATA_ROOT: RAG 模块的数据根目录
# 目录下约定包含:
#   - data: 用于 --init-rag 构建知识库的原始资料
#   - db: LightRAG 生成的索引与数据库文件
#   - models: 本地 embedding 模型目录
# 默认值: 当前项目目录下的 rag
# 例如:
#   RAG_DATA_ROOT=rag
#   RAG_DATA_ROOT=/tmp/rag
# RAG_DATA_ROOT=rag

# ===========================================
# LLM 选择配置 (可选)
# ===========================================
# 用于指定特定模式下使用的 LLM 索引（对应 LLM_X 的序号 X）
# 如果不配置，则使用随机选择

# SINGLE_THREAD_LLM: 单线程模式下使用的 LLM 索引
# 例如: SINGLE_THREAD_LLM=1 表示使用 LLM_1
# SINGLE_THREAD_LLM=1

# DUAL_THREAD_0_LLM: 双线程模式下线程1使用的 LLM 索引
# 例如: DUAL_THREAD_0_LLM=1 表示线程1使用 LLM_1
# DUAL_THREAD_0_LLM=1

# DUAL_THREAD_1_LLM: 双线程模式下线程2使用的 LLM 索引
# 例如: DUAL_THREAD_1_LLM=2 表示线程2使用 LLM_2
# DUAL_THREAD_1_LLM=2

# ===========================================
# 配置说明
# ===========================================
# LLM_X_NAME: LLM 名称，用于在代码中标识和选择模型
# LLM_X_API_KEY: API 密钥
# LLM_X_API_URL: API 基础 URL
# LLM_X_MODEL: 模型名称
# LLM_X_TIMEOUT: 请求超时时间(秒)，默认 120 秒
# LLM_X_API_TYPE: API 类型，可选值:
#   - openai: OpenAI 兼容 API (默认值，使用 Chat Completions API)
#   - anthropic: Anthropic 原生 API
#   - deepseek: DeepSeek API (推荐用于 deepseek-reasoner 模型)
# LLM_X_PROXY: 可选代理地址，仅作用于当前 LLM，例如 http://127.0.0.1:7890
#   - 配置后会强制当前 LLM 走该代理
#   - 未配置时保持 httpx 默认行为（例如可继续读取系统 HTTP_PROXY / HTTPS_PROXY）
# LLM_X_EXTRA: 可选的 JSON 对象，用于传递额外的模型初始化参数
#   - 会与代码中的默认参数递归合并
#   - 嵌套对象会保留默认值并按需覆盖，例如 model_kwargs / default_headers / reasoning
#   - 某个字段设为 null 时，会删除对应默认值，例如 {"reasoning": null}
#   - `openai` 在非 Responses 模式下默认会带上 {"extra_body":{"enable_thinking":true}}
#   - 如果需要 Responses API，可在 EXTRA 中配置 {"use_responses_api":true,...}
#
# 注意：
# 1. 使用 DeepSeek 推理模型（deepseek-reasoner）时，必须设置 API_TYPE=deepseek，
#    否则会遇到 "Missing reasoning_content field" 错误。
#    DeepSeek 普通模型（deepseek-chat）可以使用 openai 类型或 deepseek 类型。
# 2. 如果需要 OpenAI Responses API，请保持 API_TYPE=openai，并在 EXTRA 中配置
#    {"use_responses_api":true}；适用于只支持 /v1/responses 端点的 API 服务。
# 3. JSON 必须使用双引号。例如：
#    LLM_4_EXTRA={"use_responses_api":true,"use_previous_response_id":false,"reasoning":{"effort":"low","summary":"auto"}}
